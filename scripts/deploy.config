# Vietnam Hearts - Deployment Configuration
# Non-secret deployment settings. Commit this file to version control.
# Sensitive values (API keys, passwords, tokens) stay in .env

# =============================================================================
# GCP PROJECT
# =============================================================================

# GCP project ID (from Google Cloud Console)
GCP_PROJECT_ID="refined-vector-457419-n6"

# =============================================================================
# CONTAINER REGISTRY (GCR)
# =============================================================================

GCR_HOSTNAME="gcr.io"
GCR_REGION="asia-southeast1"

# =============================================================================
# DOCKER IMAGE
# =============================================================================

PROJECT_NAME="vietnam-hearts-automations"
IMAGE_NAME="vietnam-hearts-automation"
# Human-friendly version pointer only: the deploy workflow pushes this tag
# but deploys the immutable per-commit sha-<short-sha> tag to Cloud Run.
IMAGE_VERSION="v3.2.0"

# =============================================================================
# CLOUD RUN
# =============================================================================

CLOUD_RUN_SERVICE="vietnam-hearts-automation"
CLOUD_RUN_REGION="northamerica-northeast1"
BASE_URL="https://vietnam-hearts-automation-367619842919.northamerica-northeast1.run.app"

# =============================================================================
# CLOUD SCHEDULER
# =============================================================================

# NOTE: the live Cloud Scheduler jobs are in asia-southeast1 (not the Cloud Run region)
SCHEDULER_REGION="asia-southeast1"
SCHEDULER_TIMEZONE="Asia/Ho_Chi_Minh"
